  "keyFeatures": [
    "Create, search, and manage minion auctions through Discord",
    "Real-time minion price checking with tier support",
    "Multi-channel notifications (Email, Discord, Device)",
    "User authentication and profile management",
    "Direct messaging system between buyers and sellers"
  ],
  "publicApiSurface": [
    "/auctions create - Create a new minion auction",
    "/auctions search - Search for minion auctions",
    "/auctions myauctions - View your active auctions",
    "/auctions delete - Delete an auction",
    "/prices [type] [tier] - Check minion prices",
    "POST /notifications/send - Send notification to user",
    "GET /notifications/expiring_auctions - Get expiring auctions"
  ]
